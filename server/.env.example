# Copy to .env and fill in. Never commit the real .env.

# --- Cloudinary (from the Cloudinary console dashboard) ---
CLOUDINARY_CLOUD_NAME=dftjmz7l5
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=claude-edits

# --- Anthropic (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=
# Model used to turn a prompt into an edit plan. Default is the latest Opus.
EDIT_PLANNER_MODEL=claude-opus-4-8

# --- Server ---
PORT=8787
# Comma-separated allowed origins for CORS (your Pages URL). "*" allows all.
ALLOWED_ORIGINS=*
