# AI Stock Advisor Configuration
# Copy this file to .env and fill in your values

# Broker Settings
AISA_BROKER_NAME=paper          # paper, alpaca
AISA_BROKER_PAPER_MODE=true     # SAFETY: always true unless you explicitly want live trading

# Alpaca API (US stocks)
AISA_ALPACA_API_KEY=
AISA_ALPACA_API_SECRET=
AISA_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# AI Provider
AISA_AI_PROVIDER=openai         # openai, anthropic
AISA_OPENAI_API_KEY=
AISA_ANTHROPIC_API_KEY=
AISA_AI_MODEL=gpt-4o

# News API
AISA_NEWS_API_KEY=

# Risk Controls
AISA_MAX_POSITION_PCT=0.10      # Max 10% of portfolio in a single position
AISA_MAX_TOTAL_EXPOSURE_PCT=0.80
AISA_DEFAULT_STOP_LOSS_PCT=0.05
AISA_MAX_DAILY_TRADES=10
AISA_MAX_ORDER_VALUE_USD=10000.0

# General
AISA_LOCALE=en                  # en, ja
AISA_LOG_LEVEL=INFO
AISA_ANALYSIS_INTERVAL_MINUTES=60
AISA_WATCHLIST=SPY,AAPL,MSFT,GOOGL,AMZN
